{
  "manifest_version": 3,
  "name": "TechRAG Assistant",
  "version": "1.0",
  "description": "Context-aware tech news assistant with voice and emotion detection.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open TechRAG"
  },
  "permissions": [
    "audioCapture"
  ],
  "host_permissions": [
    "http://127.0.0.1:8080/*",
    "https://*/*"
  ]
}