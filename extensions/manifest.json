{
  "manifest_version": 3,
  "name": "TechRAG Assistant",
  "version": "1.0",
  "description": "Context-aware tech news assistant with voice and emotion detection.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open TechRAG"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "https://*.run.app/*", 
    "https://*/*"
  ]
}